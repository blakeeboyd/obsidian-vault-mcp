{
	"compilerOptions": {
		"baseUrl": ".",
		"module": "ESNext",
		"target": "ES2020",
		"lib": ["DOM", "ES2020"],
		"moduleResolution": "node",
		"allowJs": true,
		"noImplicitAny": true,
		"strictNullChecks": true,
		"outDir": "./dist",
		"sourceMap": true,
		"importHelpers": false,
		"isolatedModules": true
	},
	"include": ["src/**/*.ts"]
}
